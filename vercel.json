{
  "version": 2,
  "buildCommand": "npm run build --workspace=frontend",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/dashboard.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/dashboard/summary",
      "destination": "/api/dashboard"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}